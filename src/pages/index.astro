---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const top = allPosts[0];
const iconRow = allPosts.slice(0, 6); // 上部アイコン行：最新6
const showcase = allPosts.slice(0, 6); // ショウケース：最新6（2列×3行）
const archive = allPosts.slice(6); // 残り
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			:root {
				--text: #1d1d1f;
				--secondary: #6e6e73;
				--bg: #fbfbfd;
				--card: #f5f5f7;
				--link: #0066cc;
			}
			body {
				background: #fff;
				color: var(--text);
				font-family: -apple-system, BlinkMacSystemFont, 'Hiragino Sans', sans-serif;
				-webkit-font-smoothing: antialiased;
			}
			a {
				color: var(--link);
				text-decoration: none;
			}

			/* 共通：完全フルワイド(画面端まで使う) */
			.wrap {
				width: 100%;
				padding: 0 12px;
				box-sizing: border-box;
			}

			/* ===== プロモバンド（最新記事告知） ===== */
			.promo-band {
				background: var(--bg);
				padding: 0.85em 1em;
				text-align: center;
				font-size: 0.92em;
				color: var(--text);
				border-bottom: 1px solid #e5e5e7;
			}
			.promo-band a {
				color: var(--link);
			}
			.promo-band a::after {
				content: ' ›';
			}

			/* ===== タイトル＋タグライン ===== */
			.title-section {
				padding: 4em 0 0;
			}
			.title-section h1 {
				margin: 0 0 0.4em;
				font-family: 'Shippori Mincho', 'Noto Serif JP', serif;
				font-size: clamp(2em, 4.5vw, 3.6em);
				font-weight: 800;
				letter-spacing: 0.02em;
				line-height: 1.25;
				color: var(--text);
			}
			.title-section .tagline {
				margin: 0;
				font-size: clamp(1em, 1.5vw, 1.3em);
				color: var(--secondary);
				font-weight: 400;
				line-height: 1.55;
				max-width: 720px;
			}

			/* ===== 横スクロール最新記事カルーセル(四角サムネ) ===== */
			.icon-row {
				margin: 2.5em 0 4em;
				display: grid;
				grid-template-columns: repeat(6, 1fr);
				gap: 1em;
			}
			.icon-item a {
				display: block;
				text-decoration: none;
				color: var(--text);
				transition: transform 0.2s;
			}
			.icon-item a:hover {
				transform: translateY(-2px);
			}
			.icon-item .thumb {
				width: 100%;
				aspect-ratio: 1376 / 768;
				border-radius: 12px;
				overflow: hidden;
				background: var(--card);
				margin-bottom: 0.7em;
			}
			.icon-item .thumb img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
			}
			.icon-item .label {
				font-size: 0.85em;
				font-weight: 500;
				line-height: 1.5;
				color: var(--text);
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			/* ===== ショウケース見出し ===== */
			.showcase-head {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				flex-wrap: wrap;
				gap: 0.5em;
				margin: 5em 0 1.5em;
			}
			.showcase-head h2 {
				margin: 0;
				font-family: 'Shippori Mincho', 'Noto Serif JP', serif;
				font-size: clamp(1.7em, 3vw, 2.4em);
				font-weight: 800;
				letter-spacing: 0.02em;
				line-height: 1.2;
				color: var(--text);
			}
			.showcase-head .more {
				font-size: 1em;
				color: var(--link);
			}
			.showcase-head .more::after {
				content: ' ›';
			}

			/* ===== ショウケースカード（明るい色のみ・黒なし） ===== */
			.showcase-grid {
				margin: 0 0 5em;
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 1.4em;
			}
			.showcase-card {
				border-radius: 22px;
				overflow: hidden;
				transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
			}
			.showcase-card:hover {
				transform: translateY(-3px);
			}
			.showcase-card a {
				display: flex;
				flex-direction: column;
				height: 100%;
				text-decoration: none;
				color: inherit;
			}
			.showcase-card .body {
				padding: 2em 2em 1.5em;
				text-align: center;
			}
			.showcase-card .date {
				font-size: 0.78em;
				color: var(--secondary);
				margin-bottom: 0.6em;
				letter-spacing: 0.05em;
			}
			.showcase-card h3 {
				margin: 0 0 0.7em;
				font-size: clamp(1.1em, 1.5vw, 1.4em);
				font-weight: 700;
				letter-spacing: -0.01em;
				line-height: 1.4;
				color: var(--text);
			}
			.showcase-card .read {
				color: var(--link);
				font-size: 0.95em;
				font-weight: 500;
			}
			.showcase-card .read::after {
				content: ' ›';
			}
			.showcase-card .image {
				margin-top: auto;
				width: 100%;
				aspect-ratio: 1376 / 768;
			}
			.showcase-card .image img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				transition: transform 0.6s;
				display: block;
			}
			.showcase-card:hover .image img {
				transform: scale(1.04);
			}
			/* 明るい色6種類ローテ（黒なし） */
			.showcase-card:nth-child(1) { background: #f5f5f7; }
			.showcase-card:nth-child(2) { background: #fff5e6; }
			.showcase-card:nth-child(3) { background: #eef4f8; }
			.showcase-card:nth-child(4) { background: #f7f0e8; }
			.showcase-card:nth-child(5) { background: #f0f5ee; }
			.showcase-card:nth-child(6) { background: #faf3f0; }

			/* ===== 著者プロフィール ===== */
			.author-section {
				background: var(--bg);
				padding: 5em 12px;
				margin-top: 4em;
			}
			.author-card {
				max-width: 1080px;
				margin: 0 auto;
				background: #fff;
				border-radius: 22px;
				padding: 2.5em 3em;
				display: grid;
				grid-template-columns: auto 1fr;
				gap: 2.5em;
				align-items: center;
			}
			.author-photo {
				width: 140px;
				height: 140px;
				border-radius: 50%;
				object-fit: cover;
				border: 4px solid #f5f5f7;
			}
			.author-card h2 {
				margin: 0 0 0.2em;
				font-size: 1.5em;
				font-weight: 700;
				letter-spacing: -0.01em;
			}
			.author-card .tagline-author {
				margin: 0 0 1em;
				color: var(--secondary);
				font-size: 0.95em;
			}
			.author-card ul {
				margin: 0;
				padding: 0;
				list-style: none;
			}
			.author-card li {
				padding: 0.4em 0 0.4em 1.3em;
				position: relative;
				color: var(--text);
				line-height: 1.6;
				font-size: 0.93em;
			}
			.author-card li::before {
				content: '';
				position: absolute;
				left: 0;
				top: 0.95em;
				width: 5px;
				height: 5px;
				background: var(--text);
				border-radius: 50%;
			}
			.author-card li strong {
				font-weight: 700;
			}

			/* ===== アーカイブ ===== */
			.archive {
				margin: 5em 0 6em;
			}
			.archive h2 {
				margin: 0 0 1.5em;
				font-size: clamp(1.5em, 2.4vw, 2em);
				font-weight: 700;
				letter-spacing: -0.02em;
			}
			.archive-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
				gap: 1em;
			}
			.small-card a {
				display: block;
				text-decoration: none;
				color: inherit;
				border-radius: 14px;
				overflow: hidden;
				background: var(--card);
				transition: transform 0.3s;
			}
			.small-card a:hover {
				transform: translateY(-2px);
			}
			.small-card .img-wrap {
				aspect-ratio: 1376 / 768;
				overflow: hidden;
			}
			.small-card .img-wrap img {
				width: 100%;
				height: 100%;
				object-fit: cover;
			}
			.small-card .body {
				padding: 0.9em 1em 1.1em;
			}
			.small-card .date {
				font-size: 0.7em;
				color: var(--secondary);
				margin-bottom: 0.3em;
			}
			.small-card h3 {
				margin: 0;
				font-size: 0.85em;
				font-weight: 600;
				line-height: 1.5;
				color: var(--text);
			}

			/* ===== レスポンシブ ===== */
			@media (max-width: 1100px) {
				.icon-row {
					grid-template-columns: repeat(3, 1fr);
				}
			}
			@media (max-width: 768px) {
				.title-section {
					padding-top: 2em;
				}
				.icon-row {
					grid-template-columns: repeat(2, 1fr);
					margin-bottom: 3em;
				}
				.showcase-head {
					margin-top: 3em;
				}
				.showcase-grid {
					grid-template-columns: 1fr;
				}
				.author-card {
					grid-template-columns: 1fr;
					padding: 2em 1.5em;
					text-align: center;
				}
				.author-photo {
					margin: 0 auto;
				}
				.author-card ul {
					text-align: left;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<!-- ===== プロモバンド ===== -->
			{
				top && (
					<div class="promo-band">
						最新記事「{top.data.title.length > 28 ? top.data.title.slice(0, 28) + '…' : top.data.title}」<a href={`/${top.id}/`}>今すぐ読む</a>
					</div>
				)
			}

			<!-- ===== タイトル＋タグライン ===== -->
			<section class="wrap title-section">
				<h1>不用品を、後悔せず売る。</h1>
				<p class="tagline">
					元買取業界8年・累計査定3万点超のハルが、着物・骨董・ブランド・遺品整理まで、損しないための実践情報を本音で解説する買取メディア。
				</p>
			</section>

			<!-- ===== 最新記事 横並び（四角サムネ＋タイトル） ===== -->
			<section class="wrap icon-row">
				{
					iconRow.map((post) => (
						<div class="icon-item">
							<a href={`/${post.id}/`}>
								<div class="thumb">
									{post.data.heroImage && (
										<Image
											src={post.data.heroImage}
											alt={post.data.title}
											width={400}
											height={223}
										/>
									)}
								</div>
								<span class="label">{post.data.title}</span>
							</a>
						</div>
					))
				}
			</section>

			<!-- ===== ショウケース見出し ===== -->
			<div class="wrap showcase-head">
				<h2>業界の本音を、もっと。</h2>
				<a href="/blog" class="more">全記事を見る</a>
			</div>

			<!-- ===== ショウケースカード（明るい色のみ） ===== -->
			<section class="wrap showcase-grid">
				{
					showcase.map((post) => (
						<article class="showcase-card">
							<a href={`/${post.id}/`}>
								<div class="body">
									<div class="date">
										<FormattedDate date={post.data.pubDate} />
									</div>
									<h3>{post.data.title}</h3>
									<span class="read">続きを読む</span>
								</div>
								{post.data.heroImage && (
									<div class="image">
										<Image
											src={post.data.heroImage}
											alt={post.data.title}
											width={688}
											height={384}
										/>
									</div>
								)}
							</a>
						</article>
					))
				}
			</section>

			<!-- ===== 著者プロフィール ===== -->
			<section class="author-section">
				<div class="author-card">
					<img
						class="author-photo"
						src="/wp-content/uploads/2026/04/54e223b26cc676782cab36413ba4f95e.jpg"
						alt="筆者ハル"
						width="140"
						height="140"
					/>
					<div>
						<h2>筆者　ハル</h2>
						<p class="tagline-author">元買取業界8年・累計査定3万点超</p>
						<ul>
							<li>買取業界の営業として複数社で<strong>計8年勤務</strong>（お酒・骨董品・ブランド品・貴金属・着物等）</li>
							<li><strong>累計査定3万点超</strong>の現場経験</li>
							<li>廃品回収業界での実務経験もあり</li>
							<li><strong>古物商許可保有</strong></li>
							<li>業界の内側を知る目線で、読者の損を防ぐことを軸に執筆</li>
						</ul>
					</div>
				</div>
			</section>

			<!-- ===== アーカイブ ===== -->
			<section class="wrap archive">
				<h2>すべての記事</h2>
				<div class="archive-grid">
					{
						archive.map((post) => (
							<article class="small-card">
								<a href={`/${post.id}/`}>
									<div class="img-wrap">
										{post.data.heroImage && (
											<Image
												src={post.data.heroImage}
												alt={post.data.title}
												width={400}
												height={223}
											/>
										)}
									</div>
									<div class="body">
										<div class="date">
											<FormattedDate date={post.data.pubDate} />
										</div>
										<h3>{post.data.title}</h3>
									</div>
								</a>
							</article>
						))
					}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
