				</svg>
				@re_money_lab
			</a>
		</div>
		<p class="copyright">
			&copy; {today.getFullYear()} re-money-lab. All rights reserved.
		</p>
	</div>
</footer>
<style>
	footer {
		padding: 3em 1em 4em 1em;
		background: #1E3A5F;
		color: #E8E8E8;
		text-align: center;
		margin-top: 4em;
	}
	.footer-inner {
		max-width: 720px;
		margin: 0 auto;
	}
	.footer-tagline {
		font-size: 1.05em;
		margin: 0 0 0.6em 0;
		color: #fff;
	}
	.footer-desc {
		font-size: 0.88em;
		line-height: 1.7;
		color: #BBB;
		margin: 0 0 1.4em 0;
	}
	.footer-links {
		display: flex;
		justify-content: center;
		gap: 1.6em;
		margin-bottom: 1.2em;
		flex-wrap: wrap;
	}
	.footer-links a {
		color: #C8923A;
		text-decoration: none;
		font-size: 0.92em;
		font-weight: 500;
	}
	.footer-links a:hover {
		color: #E0AC4D;
		text-decoration: underline;
	}
	.social-links {
		display: flex;
		justify-content: center;
		gap: 1em;
		margin: 0 0 1.4em 0;
	}
	.social-links a {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		text-decoration: none;
		color: #DDD;
		font-size: 0.85em;
	}
	.social-links a:hover {
		color: #fff;
	}
	.copyright {
		font-size: 0.78em;
		color: #888;
		margin: 0;
	}
</style>
