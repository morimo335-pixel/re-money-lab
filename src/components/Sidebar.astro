---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

interface Props {
  related?: string[];  // 記事のfrontmatter related から渡される（slug配列）
}

const { related } = Astro.props as Props;

// デフォルトピックアップ記事（fallback・SC実測上位）
const defaultSlugs = [
  'kegawa-coat-jidai-okure',
  'komehyo-umeda-kaitori',
  'film-camera-boom-shuryou',
  'mercari-fuku-urenai',
  'takuhai-kaitori-trouble',
];

const allPosts = await getCollection('blog');

// 関連記事指定があればそれを優先・なければデフォルト
const pickupSlugs = (related && related.length > 0) ? related : defaultSlugs;
const pickupPosts = pickupSlugs
  .map(slug => allPosts.find(p => p.id === slug))
  .filter(Boolean);

const sidebarTitle = '📚 あわせて読みたい';
---

<aside class="sidebar">
  <div class="sb-title">{sidebarTitle}</div>
  <div class="sb-grid">
    {pickupPosts.map(post => post && (
      <a href={`/${post.id}/`} class="sb-card">
        <div class="sb-thumb">
          {post.data.heroImage && (
            <Image
              src={post.data.heroImage}
              alt={post.data.title}
              width={320}
              height={180}
              densities={[1.5, 2]}
              loading="lazy"
            />
          )}
        </div>
        <div class="sb-ttl">{post.data.title}</div>
      </a>
    ))}
  </div>

  <div class="sb-title" style="margin-top:24px;">🏷 カテゴリ</div>
  <div class="sb-cat">
    <a href="/">🏠 トップへ</a>
    <a href="/about/">📝 運営者情報</a>
  </div>
</aside>

<style>
  .sidebar {
    width: 320px;
    flex-shrink: 0;
    font-family: 'Shippori Mincho', 'Noto Serif JP', 'Yu Mincho', 'Hiragino Mincho ProN', serif;
    position: sticky;
    top: 20px;
    align-self: flex-start;
    max-height: calc(100vh - 40px);
    overflow-y: auto;
  }
  .sb-title {
    font-weight: bold;
    color: #1E3A5F;
    font-size: 1em;
    padding: 10px 14px;
    border-bottom: 3px solid #C8923A;
    margin-bottom: 14px;
    background: linear-gradient(135deg,#FFF8E1,#FFFFFF);
    border-radius: 6px 6px 0 0;
  }
  .sb-grid {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .sb-card {
    display: block;
    background: #FAFAFA;
    border: 1px solid #E5E9F0;
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    transition: all 0.25s;
  }
  .sb-card:hover {
    background: #fff;
    border-color: #C8923A;
    transform: translateY(-2px);
    box-shadow: 0 5px 14px rgba(0,0,0,0.10);
  }
  .sb-thumb {
    width: 100%;
    aspect-ratio: 16 / 9;
    background: #E3E8F0;
    overflow: hidden;
  }
  .sb-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .sb-ttl {
    font-size: 0.92em;
    line-height: 1.45;
    color: #1E3A5F;
    font-weight: 600;
    padding: 10px 12px 12px;
  }
  .sb-cat {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 8px;
  }
  .sb-cat a {
    color: #1E3A5F;
    text-decoration: none;
    font-size: 0.92em;
    padding: 8px 12px;
    border-radius: 4px;
    background: #F0F4F8;
    transition: background 0.2s;
  }
  .sb-cat a:hover {
    background: #E3E8F0;
  }

  @media (max-width: 1023px) {
    .sidebar {
      width: 100%;
      position: static;
      max-height: none;
      margin-top: 36px;
      padding-top: 24px;
      border-top: 2px solid #E0E0E0;
    }
    .sb-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 14px;
    }
  }

  @media (max-width: 600px) {
    .sb-grid {
      grid-template-columns: 1fr;
    }
    .sb-ttl {
      font-size: 0.88em;
    }
  }
</style>
