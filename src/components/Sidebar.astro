---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

// ピックアップ記事5本（SC実測上位＋戦略的に選定・2026-05-21）
const pickupSlugs = [
  'kegawa-coat-jidai-okure',        // 毛皮時代遅れ（SC表示123・最大）
  'komehyo-umeda-kaitori',           // コメ兵梅田（SC表示94）
  'film-camera-boom-shuryou',        // フィルムカメラ（CTR 7.8%）
  'mercari-fuku-urenai',             // メルカリ服売れない（SC表示80）
  'takuhai-kaitori-trouble',         // 宅配買取トラブル（SC表示77）
];

const allPosts = await getCollection('blog');
const pickupPosts = pickupSlugs
  .map(slug => allPosts.find(p => p.id === slug))
  .filter(Boolean);
---

<aside class="sidebar">
  <div class="sb-title">📚 ピックアップ記事</div>
  {pickupPosts.map(post => post && (
    <a href={`/${post.id}/`} class="sb-card">
      <div class="sb-thumb">
        {post.data.heroImage && (
          <Image
            src={post.data.heroImage}
            alt={post.data.title}
            width={120}
            height={68}
            loading="lazy"
          />
        )}
      </div>
      <div class="sb-ttl">{post.data.title}</div>
    </a>
  ))}

  <div class="sb-title" style="margin-top:20px;">🏷 カテゴリ</div>
  <div class="sb-cat">
    <a href="/">🏠 トップへ</a>
    <a href="/about/">📝 運営者情報</a>
  </div>
</aside>

<style>
  .sidebar {
    width: 280px;
    flex-shrink: 0;
    font-family: 'Noto Sans JP', sans-serif;
    position: sticky;
    top: 20px;
    align-self: flex-start;
    max-height: calc(100vh - 40px);
    overflow-y: auto;
  }
  .sb-title {
    font-weight: bold;
    color: #1E3A5F;
    font-size: 0.95em;
    padding: 8px 12px;
    border-bottom: 3px solid #C8923A;
    margin-bottom: 12px;
    background: linear-gradient(135deg,#FFF8E1,#FFFFFF);
    border-radius: 4px 4px 0 0;
  }
  .sb-card {
    display: flex;
    gap: 10px;
    align-items: center;
    padding: 8px;
    margin-bottom: 8px;
    background: #FAFAFA;
    border: 1px solid #E5E9F0;
    border-radius: 6px;
    text-decoration: none;
    transition: all 0.2s;
  }
  .sb-card:hover {
    background: #fff;
    border-color: #C8923A;
    transform: translateY(-1px);
    box-shadow: 0 3px 8px rgba(0,0,0,0.08);
  }
  .sb-thumb {
    width: 70px;
    height: 40px;
    flex-shrink: 0;
    border-radius: 4px;
    overflow: hidden;
    background: #E3E8F0;
  }
  .sb-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .sb-ttl {
    font-size: 0.78em;
    line-height: 1.4;
    color: #333;
    flex: 1;
    font-weight: 500;
  }
  .sb-cat {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 8px;
  }
  .sb-cat a {
    color: #1E3A5F;
    text-decoration: none;
    font-size: 0.85em;
    padding: 6px 10px;
    border-radius: 4px;
    background: #F0F4F8;
    transition: background 0.2s;
  }
  .sb-cat a:hover {
    background: #E3E8F0;
  }

  @media (max-width: 1023px) {
    .sidebar {
      width: 100%;
      position: static;
      max-height: none;
      margin-top: 30px;
      padding-top: 24px;
      border-top: 2px solid #E0E0E0;
    }
  }
</style>
