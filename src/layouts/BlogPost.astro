---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import TableOfContents from '../components/TableOfContents.astro';
import '../styles/article.css';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, related } = Astro.props;
---

<html lang="ja">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
				max-width: 1020px;
				margin: 0 auto 1em auto;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.article-container {
				display: flex;
				gap: 40px;
				max-width: 1180px;
				margin: 0 auto;
				padding: 0 1em;
				align-items: flex-start;
			}
			.prose {
				width: 760px;
				max-width: 100%;
				flex: 1;
				min-width: 0;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			@media (max-width: 1023px) {
				.article-container {
					flex-direction: column;
					gap: 0;
					padding: 0;
				}
				.prose {
					width: 100%;
					margin: 0 auto;
				}
			}
			.title {
				margin-bottom: 1.2em;
				padding: 0.8em 0;
				text-align: left;
				line-height: 1.4;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
				font-size: 1.85em;
				color: #1E3A5F;
				line-height: 1.5;
			}
			.date {
				margin-bottom: 0.7em;
				color: rgb(var(--gray));
				font-size: 0.95em;
			}
			.last-updated-on {
				font-style: italic;
			}
			hr {
				border: none;
				border-top: 2px solid #E0E0E0;
				margin: 1em 0;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="article-container">
					<div class="prose">
						<div class="title">
							<h1>{title}</h1>
							<div class="date">
								📅 <FormattedDate date={pubDate} />
								{
									updatedDate && (
										<span class="last-updated-on">
											・更新 <FormattedDate date={updatedDate} />
										</span>
									)
								}
							</div>
							<hr />
						</div>
						<div class="hero-image">
							{heroImage && <Image width={1376} height={768} src={heroImage} alt={title} />}
						</div>
						<TableOfContents />
						<slot />
					</div>
					<Sidebar related={related} />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
